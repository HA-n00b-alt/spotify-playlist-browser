{
  "name": "spotify-playlist-browser",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NODE_OPTIONS='--no-warnings' next dev",
    "build": "NODE_OPTIONS='--no-warnings' next build",
    "start": "NODE_OPTIONS='--no-warnings' next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "check:strict": "next lint",
    "check:env-contract": "node ./scripts/check-env-contract.js",
    "check:api-routes": "node ./scripts/check-api-routes.js",
    "check:runtime-console": "node ./scripts/check-runtime-console.js",
    "check:csp-cloudflare-jsd-filter": "node ./scripts/check-csp-cloudflare-jsd-filter.js",
    "test": "node --test tests/**/*.test.js",
    "verify": "node ./scripts/verify.js",
    "deploy:production": "node ./scripts/deploy-production.js"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@sentry/cli"
    ]
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.9.0",
    "@sentry/nextjs": "^10.32.1",
    "@tanstack/react-query": "^5.90.16",
    "@vercel/blob": "^2.4.0",
    "google-auth-library": "^9.0.0",
    "next": "^14.2.0",
    "pg": "^8.11.3",
    "pino": "^9.4.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/pg": "^8.10.9",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0"
  }
}
